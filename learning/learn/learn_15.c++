#include <iostream>

int main() {

    for(int i = 1; i <= 3; i++){
        std::cout << "============================================================\n";
        for(int j = 1; j <= 10; j++) {
            std::cout << j << ' ';
        }
        std::cout << "\n";
        std::cout << "============================================================\n";
    }

    return 0;
}